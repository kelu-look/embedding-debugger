[15.589634, "o", "\u001b[92m─────────────────────────────────────── \u001b[0m\u001b[1;32mSection 4 — Summary\u001b[0m\u001b[92m ────────────────────────────────────────\u001b[0m\r\n\r\n"]
[15.590696, "o", "\u001b[32m╭─\u001b[0m\u001b[32m─────────────────────────────\u001b[0m\u001b[32m \u001b[0m\u001b[1;32mEmbedding Debugger — Failure Report\u001b[0m\u001b[32m \u001b[0m\u001b[32m──────────────────────────────\u001b[0m\u001b[32m─╮\u001b[0m\r\n\u001b[32m│\u001b[0m \u001b[1mModel:\u001b[0m all-MiniLM-L6-v2                                                                          \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                                                  \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m • Safe vs dangerous procedure score gap: \u001b[1m+0.0032\u001b[0m (\u001b[31mvery small margin\u001b[0m)                             \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m • Safe ↔ dangerous cosine similarity:    \u001b[1m0.9866\u001b[0m  (\u001b[31mnearly identical\u001b[0m)                              \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m • Step reordering remains highly similar under embedding-only retrieval.                         \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                               "]
[15.590719, "o", "                                                   \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m \u001b[1mObserved behavior:\u001b[0m The pooled representation provides weak                                       \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m separation under meaning-changing order edits.                                                   \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                                                  \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m \u001b[1mImplications:\u001b[0m                                                                                    \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • RAG systems may surface dangerous or incorrect procedural documents                          \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • Semantic search cannot distinguish cause from effect                                         \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • Priority-ordered lists may be difficult to distinguish under embedding-only retrieval        \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                         "]
[15.591042, "o", "                                         \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m \u001b[1mMitigation directions:\u001b[0m                                                                           \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • Use chunked retrieval (sentence-level, not document-level)                                   \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • Re-rank with a cross-encoder that attends to order                                           \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • Augment with structural metadata (step numbers, dependency labels)                           \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • Evaluate with adversarial step-reorder test sets                                             \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                                                  \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m \u001b[2mReport written → killer_demo_report.md\u001b[0m                                                           \u001b[32m│\u001b[0m\r\n\u001b[32m╰──────────────────────"]
[15.59109, "o", "────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
