[12.571982, "o", "\u001b[3m                                         Perturbation sweep                                         \u001b[0m\r\n┏━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━━━┓\r\n┃\u001b[1m \u001b[0m\u001b[1mCategory                 \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mPerturbation               \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m   Mean Sim\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mVerdict                 \u001b[0m\u001b[1m \u001b[0m┃\r\n┡━━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━━━┩\r\n│\u001b[2m \u001b[0m\u001b[2mlexical                  \u001b[0m\u001b[2m \u001b[0m│ lowercase                   │      0.9997 "]
[12.57206, "o", "│ \u001b[32m✅ OK\u001b[0m                    │\r\n├───────────────────────────┼─────────────────────────────┼─────────────┼──────────────────────────┤\r\n│\u001b[2m \u001b[0m\u001b[2mlexical                  \u001b[0m\u001b[2m \u001b[0m│ strip_punctuation           │      0.9991 │ \u001b[32m✅ OK\u001b[0m                    │\r\n├───────────────────────────┼─────────────────────────────┼─────────────┼──────────────────────────┤\r\n│\u001b[2m \u001b[0m\u001b[2mlexical                  \u001b[0m\u001b[2m \u001b[0m│ add_typos                   │      0.9954 │ \u001b[32m✅ OK\u001b[0m                    │\r\n├───────────────────────────"]
